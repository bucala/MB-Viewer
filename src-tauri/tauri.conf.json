{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MB Viewer",
  "version": "0.1.0",
  "identifier": "com.mbviewer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MB Viewer",
        "width": 1360,
        "height": 860,
        "minWidth": 960,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["mb_viewer_thumbs.dll"],
    "fileAssociations": [
      { "ext": ["step", "stp"], "name": "STEP model", "description": "STEP CAD model", "role": "Viewer" },
      { "ext": ["iges", "igs"], "name": "IGES model", "description": "IGES CAD model", "role": "Viewer" },
      { "ext": ["brep"], "name": "BREP model", "description": "OpenCASCADE B-rep model", "role": "Viewer" },
      { "ext": ["stl"], "name": "STL mesh", "description": "Stereolithography mesh", "role": "Viewer" },
      { "ext": ["obj"], "name": "OBJ mesh", "description": "Wavefront OBJ mesh", "role": "Viewer" },
      { "ext": ["glb"], "name": "glTF binary", "description": "glTF binary scene", "role": "Viewer" }
    ]
  }
}
